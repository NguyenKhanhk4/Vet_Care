        "backgroundColor": "#87d1e8",
        "foregroundImage": "./assets/vetcare.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.duykhanhk4.vetcare"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "9364b740-b24d-4c92-8fd6-1d48b682aac3"
      }
    }
  }
}
