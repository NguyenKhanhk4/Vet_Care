{
  "expo": {
    "name": "VetCare",
    "slug": "VetCare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/vetcare.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/vetcare.png",
      "resizeMode": "contain",
      "backgroundColor": "#87d1e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.duykhanhk4.vetcare"
    },
