{
  "expo": {
    "name": "VetCare",
    "slug": "VetCare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/vetcare.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/vetcare.png",
      "resizeMode": "contain",
      "backgroundColor": "#87d1e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vetcare.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#87d1e8",
        "foregroundImage": "./assets/vetcare.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.vetcare.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar"
    ]
  }
}
